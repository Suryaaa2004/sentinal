generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  name String?
  email String @unique
  hashedPassword String?

  role String @default("user")

  createdAt DateTime @default(now())
}

model Organization {

  id String @id @default(cuid())

  name String
  domain String

  assets Asset[]

  snapshots Snapshot[]

  scans Scan[]

  createdAt DateTime @default(now())

}

model Asset {

  id String @id @default(cuid())

  domain String

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

}

model Alert {

  id String @id @default(cuid())

  title String

  description String?

  severity String

  type String @default("GENERAL")

  createdAt DateTime @default(now())

}

model Snapshot {

  id String @id @default(cuid())

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assets Json

  createdAt DateTime @default(now())

}

model Scan {

  id String @id @default(cuid())

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assetsFound Int

  driftCount Int

  status String

  createdAt DateTime @default(now())

}